FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    RHELO_DB_PATH=/data/rhelo.db \
    RHELO_API_HOST=0.0.0.0 \
    RHELO_MODE=http

WORKDIR /app
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY server.py ./
COPY rhelo_backend ./rhelo_backend

EXPOSE 5050
CMD ["python", "server.py"]
