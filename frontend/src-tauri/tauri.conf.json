{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rhelo",
  "version": "0.1.0",
  "identifier": "com.rhelo.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run verify:desktop && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rhelo Study Engine",
        "width": 800,
        "height": 600,
        "visible": false,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../rhelo.db": "rhelo.db",
      "../../ggml-base.bin": "ggml-base.bin",
      "resources/fonts/NotoSans-Regular.ttf": "fonts/NotoSans-Regular.ttf",
      "resources/fonts/NotoSansHebrew-Regular.ttf": "fonts/NotoSansHebrew-Regular.ttf",
      "resources/fonts/NotoSansDevanagari-Regular.ttf": "fonts/NotoSansDevanagari-Regular.ttf",
      "resources/fonts/NotoSansTelugu-Regular.ttf": "fonts/NotoSansTelugu-Regular.ttf",
      "resources/fonts/NotoSansMalayalam-Regular.ttf": "fonts/NotoSansMalayalam-Regular.ttf",
      "resources/fonts/NotoSansTamil-Regular.ttf": "fonts/NotoSansTamil-Regular.ttf",
      "resources/fonts/LICENSE-NOTO.txt": "fonts/LICENSE-NOTO.txt"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}
